.uh-wrapper {
  min-height: 100vh;
  font-family: 'Segoe UI', sans-serif;
  background: #050505;
  position: relative;
  transition: background 0.3s;
}

/* ── LIGHT MODE ── */
.uh-wrapper.light { background: #f8f8f6; }

.uh-wrapper.light .uh-slider { box-shadow: 0 8px 40px rgba(0,0,0,0.15); }

.uh-wrapper.light .trust-rating-name,
.uh-wrapper.light .trust-score { color: #111; }
.uh-wrapper.light .trust-ratings { border-right-color: rgba(0,0,0,0.1); }
.uh-wrapper.light .trust-divider { background: rgba(0,0,0,0.1); }
.uh-wrapper.light .trust-count { color: #555; }
.uh-wrapper.light .trust-fade-left  { background: linear-gradient(to right, #f8f8f6, transparent); }
.uh-wrapper.light .trust-fade-right { background: linear-gradient(to left,  #f8f8f6, transparent); }
.uh-wrapper.light .trust-logo-text { color: #111; }

.uh-wrapper.light .ct-heading { color: #111; }
.uh-wrapper.light .ct-desc { color: #555; }
.uh-wrapper.light .ct-color-label { color: #888; }
.uh-wrapper.light .ct-preview {
  background: transparent;
  border-color: rgba(0,0,0,0.08);
}
.uh-wrapper.light .ct-preview-label { background: rgba(0,0,0,0.35); }
.uh-wrapper.light .ct-btn { box-shadow: 0 8px 24px rgba(249,115,22,0.25); }
.uh-wrapper.light .ct-card {
  background: #fff;
  border-color: rgba(0,0,0,0.08);
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.uh-wrapper.light .ct-card:hover { border-color: rgba(249,115,22,0.4); }
.uh-wrapper.light .ct-card-name { color: #fff; }

.uh-wrapper.light .uh-banner-wrap::before { background: linear-gradient(to right, #f8f8f6, transparent); }
.uh-wrapper.light .uh-banner-wrap::after  { background: linear-gradient(to left,  #f8f8f6, transparent); }
.uh-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}
.uh-page {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  margin: 0 auto;
  padding: 6rem 1.5rem 4rem;
}

/* ── HERO ── */
.uh-hero {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 50%, #c2410c 100%);
  border-radius: 2.5rem;
  padding: 3rem;
  margin-bottom: 2rem;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 24px 64px rgba(249,115,22,0.3);
}
.uh-hero-glow {
  position: absolute;
  bottom: -60px; right: -60px;
  width: 280px; height: 280px;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  filter: blur(60px);
  pointer-events: none;
}
.uh-hero-content { position: relative; z-index: 1; }
.uh-hero-eyebrow {
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: rgba(0,0,0,0.55);
  display: block;
  margin-bottom: 0.5rem;
}
.uh-hero-name {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 900;
  color: #000;
  letter-spacing: -2px;
  font-style: italic;
  line-height: 1;
  margin-bottom: 0.75rem;
}
.uh-hero-sub {
  font-size: 0.78rem;
  font-weight: 700;
  color: rgba(0,0,0,0.6);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 1.75rem;
  max-width: 380px;
}
.uh-hero-btns { display: flex; gap: 0.75rem; flex-wrap: wrap; }
.uh-hero-btn-primary {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.85rem 1.75rem;
  background: #000; color: #fff;
  border: none; border-radius: 1rem;
  font-size: 0.72rem; font-weight: 900;
  letter-spacing: 2px; text-transform: uppercase;
  cursor: pointer; transition: all 0.2s;
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}
.uh-hero-btn-primary:hover { background: #111; transform: scale(1.04); }
.uh-hero-btn-outline {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.85rem 1.5rem;
  background: rgba(0,0,0,0.15); color: #000;
  border: 1.5px solid rgba(0,0,0,0.2); border-radius: 1rem;
  font-size: 0.72rem; font-weight: 800;
  letter-spacing: 1px; text-transform: uppercase;
  cursor: pointer; transition: all 0.2s;
}
.uh-hero-btn-outline:hover { background: rgba(0,0,0,0.25); }

.uh-hero-float {
  position: relative;
  flex-shrink: 0;
  width: 120px; height: 120px;
  display: flex; align-items: center; justify-content: center;
}
.uh-float-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2px dashed rgba(0,0,0,0.2);
  animation: uhSpin 12s linear infinite;
}
@keyframes uhSpin { to { transform: rotate(360deg); } }
.uh-float-emoji {
  font-size: 4rem;
  animation: uhFloat 3s ease-in-out infinite;
  filter: drop-shadow(0 8px 16px rgba(0,0,0,0.2));
}
@keyframes uhFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

/* ── GRID ── */
.uh-grid {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 1.5rem;
  align-items: start;
}

/* ── SECTION ── */
.uh-section { margin-bottom: 1.75rem; }
.uh-section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 1rem;
}
.uh-section-title {
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.65rem; font-weight: 900;
  color: #555; text-transform: uppercase; letter-spacing: 3px;
}
.uh-section-link {
  font-size: 0.65rem; font-weight: 700;
  color: #f97316; cursor: pointer; text-decoration: underline;
  transition: opacity 0.2s;
}
.uh-section-link:hover { opacity: 0.75; }

/* ── CATEGORIES ── */
.uh-categories {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0.75rem;
}
.uh-cat-card {
  background: rgba(17,17,17,0.85);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 1.5rem;
  padding: 1.25rem 0.5rem;
  display: flex; flex-direction: column;
  align-items: center; gap: 0.5rem;
  cursor: pointer;
  transition: all 0.2s;
  border-top: 2px solid var(--cat-color);
}
.uh-cat-card:hover {
  background: rgba(var(--cat-color), 0.1);
  box-shadow: 0 8px 24px rgba(0,0,0,0.2);
}
.uh-cat-emoji { font-size: 1.75rem; }
.uh-cat-name {
  font-size: 0.58rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: 1px;
  color: #aaa; text-align: center;
}

/* ── DRAFTS ── */
.uh-drafts-scroll {
  display: flex;
  gap: 1rem;
  overflow-x: auto;
  padding-bottom: 0.5rem;
  scrollbar-width: none;
}
.uh-drafts-scroll::-webkit-scrollbar { display: none; }
.uh-draft-card {
  flex-shrink: 0;
  width: 160px;
  background: rgba(17,17,17,0.85);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 1.5rem;
  padding: 1rem;
  display: flex; flex-direction: column;
  transition: all 0.2s;
  cursor: pointer;
}
.uh-draft-card:hover { border-color: rgba(249,115,22,0.3); transform: translateY(-3px); }
.uh-draft-thumb {
  background: rgba(255,255,255,0.04);
  border-radius: 1rem;
  height: 110px;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; margin-bottom: 0.75rem;
}
.uh-draft-thumb img { width: 80%; opacity: 0.5; object-fit: contain; }
.uh-draft-name { font-size: 0.7rem; font-weight: 700; color: #fff; margin-bottom: 0.2rem; }
.uh-draft-time { font-size: 0.58rem; color: #555; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.6rem; }
.uh-draft-resume {
  font-size: 0.6rem; font-weight: 800;
  color: #f97316; background: none; border: none;
  cursor: pointer; text-align: left; padding: 0;
  text-transform: uppercase; letter-spacing: 1px;
  transition: opacity 0.2s;
}
.uh-draft-resume:hover { opacity: 0.7; }

/* ── NOTIFICATIONS ── */
.uh-notifs { display: flex; flex-direction: column; gap: 0.5rem; }
.uh-notif {
  display: flex; align-items: center; gap: 0.85rem;
  background: rgba(17,17,17,0.85);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 1rem;
  padding: 0.85rem 1rem;
  transition: border-color 0.2s;
}
.uh-notif:hover { border-color: rgba(249,115,22,0.2); }
.uh-notif-icon { font-size: 1.3rem; flex-shrink: 0; }
.uh-notif-msg { font-size: 0.78rem; font-weight: 600; color: #ccc; }
.uh-notif-time { font-size: 0.6rem; color: #555; margin-top: 0.15rem; text-transform: uppercase; letter-spacing: 1px; }

/* ── SIDEBAR CARDS ── */
.uh-card {
  background: rgba(17,17,17,0.85);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 2rem;
  padding: 1.5rem;
  margin-bottom: 1.25rem;
}
.uh-card-header {
  display: flex; align-items: center; gap: 0.6rem;
  margin-bottom: 1.25rem;
}
.uh-card-title {
  font-size: 0.65rem; font-weight: 900;
  text-transform: uppercase; letter-spacing: 3px; color: #fff;
}
.uh-card-icon { font-size: 1rem; }
.uh-card-icon.orange { color: #f97316; }
.uh-card-icon.blue   { color: #3b82f6; }

/* Credits */
.uh-credits-row {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 0.75rem;
}
.uh-credits-label { font-size: 0.62rem; font-weight: 700; color: #555; text-transform: uppercase; letter-spacing: 1px; }
.uh-credits-val {
  display: flex; align-items: center; gap: 0.3rem;
  font-size: 1.4rem; font-weight: 900; color: #f97316; font-style: italic;
}
.uh-progress-bar {
  height: 6px; background: rgba(255,255,255,0.06);
  border-radius: 999px; overflow: hidden; margin-bottom: 0.6rem;
}
.uh-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f97316, #fb923c);
  border-radius: 999px;
}
.uh-credits-hint { font-size: 0.62rem; color: #555; margin-bottom: 1rem; }
.uh-upgrade-btn {
  display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  width: 100%; padding: 0.75rem;
  background: linear-gradient(90deg, #f59e0b, #d97706);
  border: none; border-radius: 0.85rem;
  color: #fff; font-size: 0.7rem; font-weight: 900;
  letter-spacing: 1px; text-transform: uppercase;
  cursor: pointer; transition: opacity 0.2s, transform 0.2s;
  box-shadow: 0 4px 16px rgba(245,158,11,0.3);
}
.uh-upgrade-btn:hover { opacity: 0.9; transform: translateY(-1px); }

/* Trends */
.uh-trends { display: flex; flex-direction: column; gap: 0.85rem; margin-bottom: 1.1rem; }
.uh-trend-item {
  display: flex; align-items: center; gap: 0.75rem;
  cursor: pointer; transition: all 0.15s;
}
.uh-trend-item:hover .uh-trend-name { color: #f97316; }
.uh-trend-rank { font-size: 0.65rem; font-weight: 900; color: #333; min-width: 18px; }
.uh-trend-thumb {
  width: 40px; height: 40px;
  background: rgba(255,255,255,0.05);
  border-radius: 0.6rem; flex-shrink: 0;
}
.uh-trend-name { font-size: 0.78rem; font-weight: 700; color: #fff; transition: color 0.15s; }
.uh-trend-meta { font-size: 0.6rem; color: #555; margin-top: 0.1rem; }
.uh-market-btn {
  display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  width: 100%; padding: 0.7rem;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 0.85rem;
  color: #888; font-size: 0.7rem; font-weight: 700;
  cursor: pointer; transition: all 0.2s;
}
.uh-market-btn:hover { border-color: #f97316; color: #f97316; }

/* Quick Links */
.uh-quick-links { display: flex; flex-direction: column; gap: 0.4rem; }
.uh-quick-btn {
  display: flex; align-items: center; gap: 0.6rem;
  width: 100%; padding: 0.75rem 0.85rem;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 0.85rem;
  color: rgba(255,255,255,0.65);
  font-size: 0.8rem; font-weight: 600;
  cursor: pointer; transition: all 0.15s; text-align: left;
}
.uh-quick-btn:hover { background: rgba(249,115,22,0.08); border-color: rgba(249,115,22,0.2); color: #fff; }
.uh-quick-arrow { margin-left: auto; opacity: 0; transition: opacity 0.15s; }
.uh-quick-btn:hover .uh-quick-arrow { opacity: 1; }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .uh-grid { grid-template-columns: 1fr; }
  .uh-categories { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 600px) {
  .uh-page { padding: 5rem 1rem 3rem; }
  .uh-hero { padding: 2rem 1.5rem; flex-direction: column; gap: 1.5rem; }
  .uh-hero-float { width: 80px; height: 80px; }
  .uh-float-emoji { font-size: 2.5rem; }
  .uh-categories { grid-template-columns: repeat(3, 1fr); }
  .uh-hero-name { font-size: 2rem; }
}

/* ── AUTO SCROLL BANNERS ── */
.uh-banner-wrap {
  overflow: hidden;
  position: relative;
  margin-bottom: 2rem;
}

.uh-banner-wrap::before,
.uh-banner-wrap::after {
  content: '';
  position: absolute;
  top: 0;
  width: 80px;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.uh-banner-wrap::before {
  left: 0;
  background: linear-gradient(to right, #050505, transparent);
}

.uh-banner-wrap::after {
  right: 0;
  background: linear-gradient(to left, #050505, transparent);
}

.uh-banner-track {
  display: flex;
  gap: 1.25rem;
  width: max-content;
  animation: uhBannerScroll 18s linear infinite;
  padding: 0.5rem 0;
}

.uh-banner-track:hover {
  animation-play-state: paused;
}

@keyframes uhBannerScroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

.uh-banner-card {
  flex-shrink: 0;
  width: 380px;
  height: 220px;
  border-radius: 1.5rem;
  overflow: hidden;
  position: relative;
  cursor: pointer;
  border: 1px solid rgba(255,255,255,0.07);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  transition: transform 0.3s, box-shadow 0.3s;
}

.uh-banner-card:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 16px 48px rgba(249,115,22,0.2);
  border-color: rgba(249,115,22,0.3);
}

.uh-banner-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.uh-banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 1.25rem 1.25rem 1rem;
  background: linear-gradient(to top, rgba(0,0,0,0.85), transparent);
}

.uh-banner-title {
  font-size: 0.95rem;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.3px;
  line-height: 1.2;
}

.uh-banner-sub {
  font-size: 0.7rem;
  color: rgba(255,255,255,0.6);
  margin-top: 0.2rem;
  font-weight: 500;
}

@media (max-width: 600px) {
  .uh-banner-card { width: 260px; height: 160px; }
}

/* ── 3 PICTURE SLIDER ── */
.uh-slider {
  position: relative;
  border-radius: 0;
  overflow: hidden;
  margin-bottom: 2rem;
  height: 75vh;
  max-height: 700px;
  min-height: 450px;
  margin-left: calc(-50vw + 50%);
  margin-right: calc(-50vw + 50%);
  width: 100vw;
  box-shadow: 0 8px 40px rgba(0,0,0,0.5);
}

.uh-slider-track {
  display: flex;
  height: 100%;
  width: 100%;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.uh-slide {
  min-width: 100%;
  width: 100%;
  height: 100%;
  position: relative;
  flex-shrink: 0;
  overflow: hidden;
}

.uh-slide-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.uh-slider-dots {
  position: absolute;
  bottom: 1rem;
  right: 1.25rem;
  display: flex;
  gap: 0.4rem;
}

.uh-slider-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0,0,0,0.45);
  border: 1px solid rgba(255,255,255,0.15);
  color: #fff;
  font-size: 2rem;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, transform 0.2s;
  z-index: 5;
  line-height: 1;
}

.uh-slider-arrow:hover {
  background: #f97316;
  transform: translateY(-50%) scale(1.1);
}

.uh-arrow-left  { left: 1rem; }
.uh-arrow-right { right: 1rem; }

.uh-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.35);
  cursor: pointer;
  transition: all 0.3s;
  padding: 0;
}

.uh-dot.active {
  background: #f97316;
  width: 24px;
  border-radius: 999px;
}

@media (max-width: 600px) {
  .uh-slider { height: 240px; }
  .uh-slide-title { font-size: 1rem; }
}

/* ===== TRUST SECTION ===== */
.trust-wrap {
  display: flex;
  align-items: center;
  background: transparent;
  margin-bottom: 3rem;
  margin-top: 2rem;
  overflow: hidden;
  min-height: 80px;
  padding: 1.5rem 0;
  width: 100%;
}

.trust-ratings {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 0 1.5rem 0 0;
  flex-shrink: 0;
  border-right: 1px solid rgba(255,255,255,0.08);
}

.trust-rating-box { display: flex; flex-direction: column; gap: 0.3rem; }

.trust-rating-name {
  font-size: 0.95rem;
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.5px;
  display: flex;
  align-items: center;
  gap: 0.3rem;
}

.trust-rating-row {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}

.trust-score {
  font-size: 0.75rem;
  font-weight: 900;
  color: #fff;
}

.trust-stars {
  font-size: 0.65rem;
  color: #f97316;
  letter-spacing: 1px;
}

.trust-count {
  font-size: 0.6rem;
  font-weight: 700;
  color: #aaa;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.trust-divider {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.1);
  flex-shrink: 0;
}

.trust-logos-wrap {
  position: relative;
  flex: 1;
  overflow: hidden;
  padding: 0;
  min-width: 0;
}

.trust-fade-left,
.trust-fade-right {
  position: absolute;
  top: 0;
  width: 80px;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.trust-fade-left  { left: 0;  background: linear-gradient(to right, rgba(5,5,5,0.95), transparent); }
.trust-fade-right { right: 0; background: linear-gradient(to left,  rgba(5,5,5,0.95), transparent); }

.trust-logos-track {
  display: flex;
  align-items: center;
  width: max-content;
  animation: trustScroll 30s linear infinite;
}

.trust-logos-track:hover { animation-play-state: paused; }

@keyframes trustScroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

.trust-logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 1.5rem;
  opacity: 0.35;
  transition: all 0.3s;
  cursor: pointer;
  flex-shrink: 0;
  color: #fff;
}

.uh-wrapper.light .trust-logo-item { color: #111; }

.trust-logo-item:hover { opacity: 1; }

.trust-logo-text {
  display: block;
  font-size: 1.4rem;
  font-weight: 900;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: currentColor;
  white-space: nowrap;
  font-style: italic;
}

.trust-logo-text {
  display: block;
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #fff;
  white-space: nowrap;
}

@media (max-width: 600px) {
  .trust-wrap { flex-direction: column; }
  .trust-ratings { border-right: none; border-bottom: 1px solid rgba(0,0,0,0.08); width: 100%; justify-content: center; padding: 1rem; }
}

/* ── COLOR CARDS SECTION ── */
.cc-section {
  margin-bottom: 2rem;
}

.cc-header {
  font-size: 1.4rem;
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.5px;
  margin-bottom: 1.25rem;
}

.cc-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 1rem;
}

.cc-card {
  border-radius: 1.25rem;
  overflow: hidden;
  cursor: pointer;
  border: 1px solid rgba(255,255,255,0.06);
  transition: background 0.3s, border-color 0.3s;
  padding-bottom: 0.85rem;
}

.cc-card:hover {
  border-color: var(--cc);
}

.cc-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: hidden;
}

.cc-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity 0.3s ease;
}

.cc-name {
  font-size: 0.72rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 2px;
  text-align: center;
  margin-top: 0.65rem;
  color: #fff;
}

@media (max-width: 768px) {
  .cc-grid { grid-template-columns: repeat(3, 1fr); }
}

/* ── DESIGN STUDIO SECTION ── */
.ds-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin-bottom: 3rem;
  align-items: center;
}

.ds-eyebrow {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: #f97316;
  display: block;
  margin-bottom: 0.75rem;
}

.ds-heading {
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 900;
  color: #fff;
  letter-spacing: -2px;
  line-height: 1;
  margin-bottom: 1rem;
}

.ds-heading-outline {
  -webkit-text-stroke: 2px #f97316;
  -webkit-text-fill-color: transparent;
}

.ds-desc {
  font-size: 0.85rem;
  color: #888;
  line-height: 1.8;
  margin-bottom: 1.75rem;
  max-width: 380px;
}

.ds-color-section { margin-bottom: 1.75rem; }

.ds-color-label {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #555;
  margin-bottom: 0.75rem;
}

.ds-colors {
  display: flex;
  gap: 0.6rem;
  flex-wrap: wrap;
}

.ds-color-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 3px solid transparent;
  cursor: pointer;
  transition: all 0.2s;
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
}

.ds-color-btn.active {
  border-color: #f97316 !important;
  transform: scale(1.2);
}

.ds-color-btn:hover { transform: scale(1.15); }

.ds-cta {
  padding: 0.9rem 2.5rem;
  background: #f97316;
  color: #fff;
  border: none;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 800;
  letter-spacing: 1px;
  cursor: pointer;
  box-shadow: 0 8px 24px rgba(249,115,22,0.35);
}

.ds-right {
  display: flex;
  justify-content: center;
  align-items: center;
}

.ds-preview {
  width: 320px;
  height: 360px;
  border-radius: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: background 0.4s;
  box-shadow: 0 24px 64px rgba(0,0,0,0.4);
  overflow: hidden;
}

.ds-preview-img {
  width: 75%;
  object-fit: contain;
  transition: filter 0.4s;
  position: relative;
  z-index: 1;
}

.ds-preview-badge {
  position: absolute;
  top: 1rem;
  right: 1rem;
  font-size: 0.6rem;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  background: rgba(0,0,0,0.5);
  color: #fff;
  padding: 0.3rem 0.75rem;
  border-radius: 999px;
  backdrop-filter: blur(8px);
}

/* ── UPDATED COLOR CARDS ── */
.cc-section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 1.5rem;
}

.cc-header {
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 900;
  color: #fff;
  letter-spacing: -1px;
  line-height: 1.1;
  margin-bottom: 0;
}

.cc-header-outline {
  -webkit-text-stroke: 2px #f97316;
  -webkit-text-fill-color: transparent;
}

.cc-view-all {
  padding: 0.6rem 1.5rem;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 999px;
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.2s;
}

.cc-view-all:hover { border-color: #f97316; color: #f97316; }

.cc-hover-overlay {
  position: absolute;
  inset: 0;
  opacity: 0.15;
  transition: opacity 0.3s;
  pointer-events: none;
}

.cc-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0.25rem;
  margin-top: 0.65rem;
}

.cc-arrow {
  font-size: 1rem;
  font-weight: 900;
  transition: transform 0.2s;
}

.cc-card:hover .cc-arrow { transform: translateX(4px); }

@media (max-width: 768px) {
  .ds-section { grid-template-columns: 1fr; }
  .ds-preview { width: 100%; height: 260px; }
}

/* ── CUSTOM TSHIRT SECTION ── */
.ct-section {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 2.5rem;
  margin-bottom: 3rem;
  margin-top: 3rem;
  align-items: start;
}

.ct-eyebrow {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: #f97316;
  display: block;
  margin-bottom: 0.75rem;
}

.ct-heading {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 900;
  color: #fff;
  letter-spacing: -2px;
  line-height: 1;
  margin-bottom: 0.85rem;
}

.ct-heading-outline {
  -webkit-text-stroke: 2px #f97316;
  -webkit-text-fill-color: transparent;
}

.ct-desc {
  font-size: 0.82rem;
  color: #666;
  line-height: 1.7;
  margin-bottom: 1.5rem;
}

.ct-color-label {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #555;
  margin-bottom: 0.6rem;
}

.ct-colors {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}

.ct-color-dot {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  border: 2.5px solid transparent;
  cursor: pointer;
  transition: all 0.2s;
  box-shadow: 0 2px 6px rgba(0,0,0,0.4);
  outline: none;
}

.ct-color-dot:hover { transform: scale(1.2); }
.ct-color-dot.active {
  border-color: #fff;
  transform: scale(1.25);
  box-shadow: 0 0 0 3px rgba(255,255,255,0.25);
}

.ct-preview {
  width: 100%;
  height: 160px;
  border-radius: 1.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 1.25rem;
  overflow: hidden;
  background: transparent;
  border: 1px solid rgba(255,255,255,0.1);
}

.ct-preview-img {
  height: 80%;
  object-fit: contain;
  display: block;
}

.ct-preview-label {
  position: absolute;
  top: 0.75rem;
  right: 0.75rem;
  font-size: 0.55rem;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  background: rgba(0,0,0,0.5);
  color: #fff;
  padding: 0.25rem 0.6rem;
  border-radius: 999px;
  backdrop-filter: blur(8px);
}

.ct-btn {
  width: 100%;
  padding: 0.9rem;
  background: #f97316;
  color: #fff;
  border: none;
  border-radius: 1rem;
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 1px;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  box-shadow: 0 8px 24px rgba(249,115,22,0.35);
}

.ct-btn:hover { background: #ea580c; transform: translateY(-2px); }

/* Right Grid */
.ct-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.65rem;
}

.ct-card {
  border-radius: 0.85rem;
  overflow: hidden;
  cursor: pointer;
  position: relative;
  aspect-ratio: 1/1;
  background: transparent;
  box-shadow: none;
  transition: transform 0.3s, box-shadow 0.3s;
}

.ct-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 12px 40px rgba(0,0,0,0.5);
}

.ct-card-img-wrap {
  position: absolute;
  inset: 0;
}

.ct-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transition: transform 0.5s ease;
  image-rendering: -webkit-optimize-contrast;
}

.ct-card:hover .ct-card-img { transform: scale(1.08); }

.ct-card-footer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 2rem 0.85rem 0.85rem;
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  opacity: 1;
  transition: opacity 0.3s;
}

.ct-card-name {
  font-size: 0.68rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #fff;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
}

.ct-card-arrow {
  font-size: 0.9rem;
  font-weight: 900;
  color: #f97316;
  transition: transform 0.2s;
  opacity: 0;
}

.ct-card:hover .ct-card-arrow {
  transform: translateX(4px);
  opacity: 1;
}

@media (max-width: 1024px) {
  .ct-section { grid-template-columns: 1fr; }
  .ct-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 600px) {
  .ct-grid { grid-template-columns: repeat(2, 1fr); }
}

/* ── HOW IT WORKS SECTION ── */
.hiw-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  margin: 4rem 0;
  overflow: hidden;
}

.hiw-eyebrow {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: #f97316;
  display: block;
  margin-bottom: 0.85rem;
}

.hiw-heading {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 900;
  color: #fff;
  letter-spacing: -2px;
  line-height: 1.05;
  margin-bottom: 1rem;
}

.hiw-heading-accent {
  -webkit-text-stroke: 2px #f97316;
  -webkit-text-fill-color: transparent;
}

.hiw-desc {
  font-size: 0.85rem;
  color: #666;
  line-height: 1.8;
  margin-bottom: 2rem;
  max-width: 380px;
}

.hiw-steps {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  margin-bottom: 2rem;
}

.hiw-step {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

.hiw-step-num {
  font-size: 1.4rem;
  font-weight: 900;
  color: #f97316;
  font-style: italic;
  line-height: 1;
  min-width: 36px;
  opacity: 0.9;
}

.hiw-step-title {
  font-size: 0.85rem;
  font-weight: 800;
  color: #fff;
  margin-bottom: 0.2rem;
}

.hiw-step-desc {
  font-size: 0.75rem;
  color: #555;
}

.hiw-btn {
  padding: 0.85rem 2rem;
  background: #f97316;
  color: #fff;
  border: none;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 800;
  letter-spacing: 1px;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  box-shadow: 0 8px 24px rgba(249,115,22,0.35);
}

.hiw-btn:hover { background: #ea580c; transform: translateY(-2px); }

/* Right — scrolling frames */
.hiw-right {
  position: relative;
  height: 520px;
  overflow: visible;
}

.hiw-right::before,
.hiw-right::after {
  content: '';
  position: absolute;
  left: -10%; right: -10%;
  height: 120px;
  z-index: 2;
  pointer-events: none;
  display: none;
}

.hiw-scroll-wrap {
  transform: rotate(-6deg) scale(1.15);
  height: 100%;
  overflow: hidden;
}

.hiw-scroll-track {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  animation: hiwScroll 20s linear infinite;
}

.hiw-scroll-track:hover { animation-play-state: paused; }

@keyframes hiwScroll {
  from { transform: translateY(0); }
  to   { transform: translateY(-50%); }
}

.hiw-frame {
  border-radius: 1.25rem;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 16px 48px rgba(0,0,0,0.6);
  border: 1px solid rgba(255,255,255,0.1);
  background: #111;
}

.hiw-frame img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: contain;
}

.hiw-frame-0 { transform: translateX(-20px); }
.hiw-frame-1 { transform: translateX(20px); }
.hiw-frame-2 { transform: translateX(-8px); }

/* light mode */
.uh-wrapper.light .hiw-heading { color: #111; }
.uh-wrapper.light .hiw-desc { color: #555; }
.uh-wrapper.light .hiw-step-title { color: #111; }
.uh-wrapper.light .hiw-right::before { background: linear-gradient(to bottom, #f8f8f6 40%, transparent); }
.uh-wrapper.light .hiw-right::after  { background: linear-gradient(to top,   #f8f8f6 40%, transparent); }

@media (max-width: 900px) {
  .hiw-section { grid-template-columns: 1fr; gap: 2rem; }
  .hiw-right { height: 300px; }
}

/* ── CT FEATURES ── */
.ct-features {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.ct-feature {
  display: flex;
  align-items: center;
  gap: 0.85rem;
  padding: 0.65rem 0.85rem;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 0.85rem;
  transition: border-color 0.2s;
}

.ct-feature:hover { border-color: rgba(249,115,22,0.3); }

.ct-feature-icon {
  font-size: 1.2rem;
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(249,115,22,0.1);
  border-radius: 0.6rem;
}

.ct-feature-title {
  font-size: 0.78rem;
  font-weight: 800;
  color: #fff;
  margin-bottom: 0.1rem;
}

.ct-feature-sub {
  font-size: 0.65rem;
  color: #555;
}

.uh-wrapper.light .ct-feature { background: rgba(0,0,0,0.03); border-color: rgba(0,0,0,0.08); }
.uh-wrapper.light .ct-feature-title { color: #111; }

/* ── PRODUCT GRID SECTION ── */
.uh-products-section {
  margin: 4rem 0;
}

.uh-products-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 2rem;
}

/* ── DESIGN STUDIO WRAP ── */
.ct-section-wrap {
  position: relative;
  border-radius: 2rem;
  padding: 2.5rem;
  margin-bottom: 3rem;
  margin-top: 3rem;
  background: rgba(255,255,255,0.04);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255,255,255,0.1);
  box-shadow: 0 8px 48px rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.08);
}

.ct-section-wrap .ct-section {
  margin: 0;
}

.uh-wrapper.light .ct-section-wrap {
  background: rgba(255,255,255,0.7);
  border-color: rgba(0,0,0,0.08);
  box-shadow: 0 8px 48px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.9);
}

/* sections inside wrap — margin reset */
.ct-section-wrap .hiw-section { margin: 0; }
.ct-section-wrap .uh-products-section { margin: 0; }

/* ── USER PRODUCT GRID ── */
.upg-wrap {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.upg-tshirts {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.upg-tshirt-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  cursor: pointer;
  padding: 0.5rem;
  border-radius: 1rem;
  border: 2px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  transition: all 0.2s;
  width: 90px;
}

.upg-tshirt-btn:hover { border-color: rgba(249,115,22,0.4); }
.upg-tshirt-btn.active { border-color: #f97316; background: rgba(249,115,22,0.08); }

.upg-tshirt-img-wrap {
  width: 70px;
  height: 70px;
  border-radius: 0.65rem;
  overflow: hidden;
  background: rgba(255,255,255,0.05);
}

.upg-tshirt-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.upg-tshirt-name {
  font-size: 0.6rem;
  font-weight: 700;
  color: #aaa;
  text-transform: uppercase;
  letter-spacing: 1px;
  text-align: center;
}

.upg-tshirt-btn.active .upg-tshirt-name { color: #f97316; }

.upg-main {
  display: grid;
  grid-template-columns: 1fr 200px;
  gap: 1.5rem;
  align-items: start;
}

.upg-canvas-wrap {
  position: relative;
  border-radius: 1.5rem;
  overflow: hidden;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  aspect-ratio: 1;
}

.upg-canvas-badge {
  position: absolute;
  top: 0.75rem;
  right: 0.75rem;
  font-size: 0.55rem;
  font-weight: 800;
  letter-spacing: 1px;
  text-transform: uppercase;
  background: rgba(34,197,94,0.9);
  color: #fff;
  padding: 0.25rem 0.6rem;
  border-radius: 999px;
}

.upg-logos { display: flex; flex-direction: column; gap: 0.75rem; }

.upg-logos-label {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #555;
}

.upg-logos-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.5rem;
}

.upg-logo-btn {
  aspect-ratio: 1;
  border-radius: 0.75rem;
  border: 2px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04);
  cursor: pointer;
  padding: 0.4rem;
  transition: all 0.2s;
  overflow: hidden;
}

.upg-logo-btn img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.upg-logo-btn:hover { border-color: rgba(249,115,22,0.4); }
.upg-logo-btn.active { border-color: #f97316; background: rgba(249,115,22,0.1); }

.upg-cta {
  grid-column: 1 / -1;
  padding: 0.9rem;
  background: #f97316;
  color: #fff;
  border: none;
  border-radius: 1rem;
  font-size: 0.82rem;
  font-weight: 800;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  box-shadow: 0 8px 24px rgba(249,115,22,0.35);
}

.upg-cta:hover { background: #ea580c; transform: translateY(-2px); }

@media (max-width: 768px) {
  .upg-main { grid-template-columns: 1fr; }
}

/* ── COLLECTION SPLIT SECTION ── */
.coll-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}

.coll-images {
  position: relative;
  height: 480px;
}

.coll-img-stack {
  position: relative;
  width: 100%;
  height: 100%;
}

.coll-img-card {
  position: absolute;
  border-radius: 1.25rem;
  overflow: hidden;
  box-shadow: 0 16px 48px rgba(0,0,0,0.4);
  border: 1px solid rgba(255,255,255,0.08);
  transition: transform 0.4s cubic-bezier(0.4,0,0.2,1), box-shadow 0.4s;
  cursor: pointer;
}

.coll-img-card:hover {
  box-shadow: 0 24px 64px rgba(249,115,22,0.3);
  z-index: 10 !important;
}

.coll-img-1:hover { transform: rotate(-2deg) scale(1.06); }
.coll-img-2:hover { transform: rotate(2deg) scale(1.06); }
.coll-img-3:hover { transform: rotate(-1deg) scale(1.06); }

.coll-img-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.coll-img-1 {
  width: 65%;
  height: 55%;
  top: 0;
  left: 0;
  z-index: 3;
  transform: rotate(-2deg);
}

.coll-img-2 {
  width: 60%;
  height: 50%;
  top: 25%;
  right: 0;
  z-index: 2;
  transform: rotate(2deg);
}

.coll-img-3 {
  width: 55%;
  height: 45%;
  bottom: 0;
  left: 10%;
  z-index: 1;
  transform: rotate(-1deg);
}

.coll-info {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.coll-steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: 1.5rem 0 2rem;
}

.coll-step {
  display: flex;
  align-items: flex-start;
  gap: 1.25rem;
  padding: 1rem 0;
  position: relative;
  border: none;
  background: none;
  border-radius: 0;
  transition: none;
}

.coll-step:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 20px;
  top: 56px;
  width: 2px;
  height: calc(100% - 16px);
  background: linear-gradient(to bottom, rgba(249,115,22,0.4), rgba(249,115,22,0.05));
}

.coll-step:hover { border-color: transparent; background: none; }

.coll-step-icon {
  width: 42px;
  height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(249,115,22,0.1);
  border-radius: 50%;
  flex-shrink: 0;
  border: 1.5px solid rgba(249,115,22,0.25);
  position: relative;
  z-index: 1;
  transition: all 0.2s;
}

.coll-step:hover .coll-step-icon {
  background: #f97316;
  border-color: #f97316;
}

.coll-step:hover .coll-step-icon svg { stroke: #fff; }

.coll-step-title {
  font-size: 0.88rem;
  font-weight: 900;
  color: #fff;
  margin-bottom: 0.2rem;
  letter-spacing: -0.3px;
}

.coll-step-desc {
  font-size: 0.72rem;
  color: #555;
  line-height: 1.6;
}

/* light mode */
.uh-wrapper.light .coll-step { background: none; border-color: transparent; }
.uh-wrapper.light .coll-step:hover { background: none; }
.uh-wrapper.light .coll-step-title { color: #111; }
.uh-wrapper.light .coll-img-card { border-color: rgba(0,0,0,0.08); }
.uh-wrapper.light .coll-step::after { background: linear-gradient(to bottom, rgba(249,115,22,0.3), transparent); }

@media (max-width: 900px) {
  .coll-split { grid-template-columns: 1fr; }
  .coll-images { height: 300px; }
}

/* ── PROMO BANNER ── */
.promo-banner {
  position: relative;
  border-radius: 2rem;
  overflow: hidden;
  margin: 3rem 0;
  background: linear-gradient(135deg, #0a0a0a 0%, #1a0a00 50%, #f97316 150%);
  border: 1px solid rgba(249,115,22,0.2);
  box-shadow: 0 24px 80px rgba(249,115,22,0.15);
}

.promo-bg-glow {
  position: absolute;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(249,115,22,0.12);
  filter: blur(80px);
  top: -100px; right: -100px;
  pointer-events: none;
}

.promo-bg-glow-2 {
  width: 250px; height: 250px;
  background: rgba(249,115,22,0.08);
  bottom: -80px; left: 20%;
  top: auto;
}

.promo-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 3rem 3.5rem;
  gap: 2rem;
}

.promo-left {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  max-width: 480px;
}

.promo-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #f97316;
  background: rgba(249,115,22,0.12);
  border: 1px solid rgba(249,115,22,0.25);
  padding: 0.35rem 0.85rem;
  border-radius: 999px;
  width: fit-content;
}

.promo-heading {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  color: #fff;
  letter-spacing: -2px;
  line-height: 1.05;
  margin: 0;
}

.promo-heading-accent {
  color: #f97316;
  -webkit-text-stroke: 0;
}

.promo-desc {
  font-size: 0.85rem;
  color: #888;
  line-height: 1.7;
  margin: 0;
}

.promo-code-wrap {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.promo-code {
  font-size: 1rem;
  font-weight: 900;
  letter-spacing: 4px;
  color: #f97316;
  background: rgba(249,115,22,0.1);
  border: 2px dashed rgba(249,115,22,0.4);
  padding: 0.6rem 1.25rem;
  border-radius: 0.75rem;
  font-family: monospace;
}

.promo-copy {
  font-size: 0.72rem;
  font-weight: 800;
  color: #fff;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  padding: 0.6rem 1.25rem;
  border-radius: 0.75rem;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 1px;
}

.promo-copy:hover { background: rgba(255,255,255,0.15); }

.promo-cta {
  width: fit-content;
  padding: 0.9rem 2.5rem;
  background: #f97316;
  color: #fff;
  border: none;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 900;
  cursor: pointer;
  letter-spacing: 1px;
  transition: all 0.2s;
  box-shadow: 0 8px 32px rgba(249,115,22,0.4);
}

.promo-cta:hover { background: #ea580c; transform: translateY(-2px); }

.promo-right { flex-shrink: 0; }

.promo-badge-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
}

.promo-badge {
  width: 130px; height: 130px;
  border-radius: 50%;
  background: linear-gradient(135deg, #f97316, #ea580c);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16px 48px rgba(249,115,22,0.5);
  border: 4px solid rgba(255,255,255,0.15);
}

.promo-badge-num {
  font-size: 2.2rem;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  letter-spacing: -2px;
}

.promo-badge-label {
  font-size: 0.75rem;
  font-weight: 900;
  color: rgba(255,255,255,0.8);
  letter-spacing: 4px;
}

.promo-stats {
  display: flex;
  gap: 1.5rem;
}

.promo-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
}

.promo-stat span {
  font-size: 1.1rem;
  font-weight: 900;
  color: #fff;
  letter-spacing: -0.5px;
}

.promo-stat p {
  font-size: 0.6rem;
  color: #666;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 700;
  text-align: center;
}

@media (max-width: 768px) {
  .promo-content { flex-direction: column; padding: 2rem; }
  .promo-right { width: 100%; }
  .promo-badge-wrap { flex-direction: row; justify-content: center; }
}

/* ── LIGHT MODE TEXT FIXES ── */
.uh-wrapper.light .ct-heading { color: #111; }
.uh-wrapper.light .ct-heading-outline { -webkit-text-stroke-color: #f97316; }
.uh-wrapper.light .ct-desc { color: #444; }
.uh-wrapper.light .ct-eyebrow { color: #f97316; }
.uh-wrapper.light .ct-color-label { color: #555; }
.uh-wrapper.light .hiw-heading { color: #111; }
.uh-wrapper.light .hiw-desc { color: #444; }
.uh-wrapper.light .hiw-step-title { color: #111; }
.uh-wrapper.light .hiw-step-desc { color: #666; }
.uh-wrapper.light .hiw-step-num { color: #f97316; }
.uh-wrapper.light .coll-step-title { color: #111; }
.uh-wrapper.light .coll-step-desc { color: #555; }
.uh-wrapper.light .trust-rating-name { color: #111; }
.uh-wrapper.light .trust-score { color: #111; }
.uh-wrapper.light .trust-count { color: #555; }
.uh-wrapper.light .trust-logo-text { color: #111; }
.uh-wrapper.light .ct-section-wrap {
  background: rgba(0,0,0,0.04);
  border-color: rgba(0,0,0,0.08);
}
.uh-wrapper.light .promo-heading { color: #fff; }
.uh-wrapper.light .promo-desc { color: rgba(255,255,255,0.7); }

/* ── DARK MODE TEXT FIXES ── */
.uh-wrapper .ct-heading { color: #fff; }
.uh-wrapper .ct-desc { color: #888; }
.uh-wrapper .hiw-heading { color: #fff; }
.uh-wrapper .hiw-desc { color: #666; }
.uh-wrapper .hiw-step-title { color: #fff; }
.uh-wrapper .hiw-step-desc { color: #555; }
.uh-wrapper .coll-step-title { color: #fff; }
.uh-wrapper .coll-step-desc { color: #555; }
.uh-wrapper .trust-rating-name { color: #fff; }
.uh-wrapper .trust-score { color: #fff; }
/* ── NEW DROPS ── */
.new-drops-section {
  padding: 4rem 0;
  overflow: hidden;
}

.new-drops-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 2.5rem;
}

.new-drops-section .uh-eyebrow {
  display: block;
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: #f97316;
  margin-bottom: 0.5rem;
}

.new-drops-section .uh-heading {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 900;
  color: #fff;
  letter-spacing: -1.5px;
  line-height: 1.1;
}

.uh-heading-outline {
  -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.4);
  -webkit-text-fill-color: transparent;
}

.uh-view-all {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 0.75rem 1.5rem;
  border-radius: 999px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.uh-view-all:hover {
  background: #f97316;
  border-color: #f97316;
  transform: translateX(5px);
}

.new-drops-slider {
  overflow-x: auto;
  padding: 1rem 0 3rem;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.new-drops-slider::-webkit-scrollbar {
  display: none;
}

.new-drops-track {
  display: flex;
  gap: 1.5rem;
}

.new-drop-card {
  flex-shrink: 0;
  width: 300px;
  cursor: pointer;
}

.new-drop-img-wrap {
  position: relative;
  aspect-ratio: 4/5;
  border-radius: 1.5rem;
  overflow: hidden;
  background: #111;
  margin-bottom: 1.25rem;
}

.new-drop-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
}

.new-drop-card:hover .new-drop-img {
  transform: scale(1.1);
}

.new-drop-tag {
  position: absolute;
  top: 1.25rem;
  left: 1.25rem;
  background: #f97316;
  color: #fff;
  font-size: 0.6rem;
  font-weight: 900;
  padding: 0.3rem 0.75rem;
  border-radius: 4px;
  letter-spacing: 1px;
  z-index: 2;
}

.new-drop-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.4), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.new-drop-card:hover .new-drop-overlay {
  opacity: 1;
}

.new-drop-title {
  font-size: 1.1rem;
  font-weight: 800;
  color: #fff;
  margin-bottom: 0.25rem;
  letter-spacing: -0.3px;
}

.new-drop-price {
  font-size: 0.9rem;
  font-weight: 600;
  color: #f97316;
}

.uh-wrapper.light .new-drop-title { color: #111; }

/* ── NEW DROPS 4 CARDS FIX ── */
.new-drops-track {
  display: grid !important;
  grid-template-columns: repeat(4, 1fr) !important;
  gap: 1rem !important;
  overflow: visible !important;
  width: 100% !important;
}

.new-drop-price { display: none !important; }

@media (max-width: 768px) {
  .new-drops-track { grid-template-columns: repeat(2, 1fr) !important; }
}

/* ── NEW DROP CARDS FULL FRAME FIX ── */
.new-drops-section { width: 100%; }
.new-drops-slider { width: 100%; overflow: hidden; }

.new-drops-track {
  display: grid !important;
  grid-template-columns: repeat(4, 1fr) !important;
  gap: 1rem !important;
  width: 100% !important;
}

.new-drop-card {
  width: 100% !important;
  flex-shrink: unset !important;
  cursor: pointer;
  border-radius: 1.25rem;
  overflow: hidden;
}

.new-drop-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 3/4;
  overflow: hidden;
}

.new-drop-img {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
  display: block;
  transition: transform 0.4s ease;
}

.new-drop-card:hover .new-drop-img { transform: scale(1.06); }

@media (max-width: 768px) {
  .new-drops-track { grid-template-columns: repeat(2, 1fr) !important; }
}

/* ── NEW DROPS PAIRS ── */
.new-drops-pairs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

.new-drop-pair {
  display: flex;
  align-items: center;
  gap: 0;
  border-radius: 1.5rem;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  position: relative;
}

.new-drop-pair .new-drop-card {
  flex: 1;
  cursor: pointer;
  overflow: hidden;
  border-radius: 0;
}

.new-drop-pair .new-drop-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 3/4;
  overflow: hidden;
}

.new-drop-pair .new-drop-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.new-drop-pair .new-drop-card:hover .new-drop-img { transform: scale(1.06); }

.new-drop-pair .new-drop-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);
}

.new-drop-pair .new-drop-tag {
  position: absolute;
  top: 0.75rem;
  left: 0.75rem;
  font-size: 0.55rem;
  font-weight: 900;
  letter-spacing: 2px;
  background: #f97316;
  color: #fff;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
}

.new-drop-name {
  position: absolute;
  bottom: 0.75rem;
  left: 0.75rem;
  right: 0.75rem;
  font-size: 0.72rem;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  z-index: 2;
}

.new-drop-bolt {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
  width: 44px;
  height: 44px;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(249,115,22,0.5);
  border: 2px solid rgba(249,115,22,0.3);
  flex-shrink: 0;
}

.uh-wrapper.light .new-drop-pair {
  border-color: rgba(0,0,0,0.08);
  background: rgba(0,0,0,0.03);
}

@media (max-width: 768px) {
  .new-drops-pairs { grid-template-columns: 1fr; }
}

/* ── NEW DROPS SPLIT BOX ── */

/* ── NEW DROPS SPLIT BOX ── */
.nd-grid {
  display: flex;
  gap: 1rem;
}

.nd-split-box {
  width: 280px;
  flex-shrink: 0;
  border-radius: 1.25rem;
  overflow: hidden;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(255,255,255,0.08);
  background: #111;
  transition: transform 0.3s, box-shadow 0.3s;
}

.nd-split-box:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 50px rgba(0,0,0,0.5), 0 0 0 1px var(--box-color);
}

.nd-split-top, .nd-split-bottom {
  position: relative;
  width: 100%;
  height: 185px;
  overflow: hidden;
  flex-shrink: 0;
}

.nd-split-top img, .nd-split-bottom img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform 0.5s;
}

.nd-split-box:hover .nd-split-top img,
.nd-split-box:hover .nd-split-bottom img { transform: scale(1.06); }

.nd-split-overlay-top {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 55%);
  z-index: 1;
}

.nd-split-overlay-bottom {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.75) 0%, transparent 55%);
  z-index: 1;
}

.nd-split-tag {
  position: absolute;
  top: 0.6rem; left: 0.6rem;
  font-size: 0.5rem; font-weight: 900;
  letter-spacing: 2px; color: #fff;
  padding: 0.18rem 0.55rem;
  border-radius: 999px; z-index: 3;
}

.nd-split-name {
  position: absolute;
  left: 0.7rem; right: 0.7rem;
  font-size: 0.72rem; font-weight: 800;
  color: #fff; text-shadow: 0 1px 6px rgba(0,0,0,0.8);
  z-index: 3; line-height: 1.3;
}

.nd-split-name-top { bottom: 0.7rem; }
.nd-split-name-bottom { top: 0.7rem; }

.nd-split-center {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 52px;
  background: #111;
  flex-shrink: 0;
}

.nd-split-line {
  flex: 1;
  height: 1.5px;
  background: linear-gradient(90deg, transparent, var(--box-color), transparent);
  box-shadow: 0 0 8px var(--box-glow);
}

.nd-split-icon {
  width: 48px; height: 48px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem; flex-shrink: 0;
  transition: transform 0.3s;
}

.nd-split-box:hover .nd-split-icon { transform: scale(1.2); }

.nd-split-icon span {
  display: inline-block;
  animation: iconFloat 2s ease-in-out infinite;
}

@keyframes iconFloat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

/* ── SHATTERED GLASS PRODUCT CARD ── */
:root {
  --energy-orange: #ff6a00;
  --energy-glow: rgba(255,106,0,0.6);
}

.nd-grid {
  display: flex;
  gap: 1.5rem;
}

.product-card {
  position: relative;
  width: 300px;
  height: 520px;
  background: #111;
  border-radius: 20px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  cursor: pointer;
  flex-shrink: 0;
  transition: transform 0.3s, box-shadow 0.3s;
  border: 1px solid rgba(255,255,255,0.08);
}

.product-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 24px 60px rgba(0,0,0,0.6), 0 0 0 1px var(--energy-orange);
}

.panel {
  position: relative;
  height: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.panel img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s;
}

.product-card:hover .panel img { transform: scale(1.05); }

.product-title {
  position: absolute;
  bottom: 20px;
  left: 15px;
  right: 15px;
  color: #fff;
  font-size: 0.78rem;
  font-weight: 800;
  text-shadow: 2px 2px 10px rgba(0,0,0,0.8);
  margin: 0;
  line-height: 1.3;
  z-index: 3;
}

.bottom-panel .product-title {
  bottom: auto;
  top: 20px;
}

.badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--energy-orange);
  color: #fff;
  padding: 4px 12px;
  border-radius: 999px;
  font-weight: 900;
  font-size: 0.5rem;
  letter-spacing: 2px;
  z-index: 3;
}

/* Top panel dark gradient bottom */
.top-panel::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
  z-index: 1;
}

/* Bottom panel dark gradient top */
.bottom-panel::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, transparent 50%);
  z-index: 1;
}

/* Divider */
.divider-section {
  position: absolute;
  top: 50%;
  width: 100%;
  height: 60px;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* Zig-zag crack lines */
.crack-line {
  flex: 1;
  height: 3px;
  position: relative;
}

.crack-left {
  background: linear-gradient(90deg, transparent, var(--energy-orange));
  clip-path: polygon(0 40%, 10% 0, 25% 60%, 40% 10%, 55% 50%, 70% 0, 85% 60%, 100% 20%, 100% 80%, 85% 100%, 70% 40%, 55% 90%, 40% 50%, 25% 100%, 10% 40%, 0 60%);
  box-shadow: 0 0 12px var(--energy-orange);
}

.crack-right {
  background: linear-gradient(90deg, var(--energy-orange), transparent);
  clip-path: polygon(0 20%, 15% 60%, 30% 0, 45% 50%, 60% 10%, 75% 60%, 90% 0, 100% 40%, 100% 60%, 90% 20%, 75% 80%, 60% 30%, 45% 70%, 30% 20%, 15% 80%, 0 40%);
  box-shadow: 0 0 12px var(--energy-orange);
}

/* Bolt Nexus */
.bolt-nexus {
  position: relative;
  width: 72px;
  height: 72px;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.glow-effect {
  position: absolute;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, var(--energy-glow) 0%, transparent 70%);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

.bolt-icon {
  font-size: 2.2rem;
  color: #fff;
  filter: drop-shadow(0 0 10px var(--energy-orange)) drop-shadow(0 0 20px var(--energy-orange));
  z-index: 11;
  position: relative;
  animation: boltPop 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.4); opacity: 1; }
}

@keyframes boltPop {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 0 10px var(--energy-orange)); }
  50% { transform: scale(1.15); filter: drop-shadow(0 0 20px #fff) drop-shadow(0 0 30px var(--energy-orange)); }
}

/* Glass Shatter SVG Overlay */
.glass-shatter-overlay {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
  z-index: 20;
  opacity: 0.6;
}

.product-card:hover .glass-shatter-overlay { opacity: 0.9; }

/* ── REAL CRACK LINES OVERRIDE ── */
.crack-line {
  flex: 1;
  position: relative;
  height: 24px;
  overflow: visible;
  background: none !important;
  clip-path: none !important;
  box-shadow: none !important;
}

.crack-left,
.crack-right {
  background: none !important;
  clip-path: none !important;
  box-shadow: none !important;
}

.crack-left::before {
  content: '';
  position: absolute;
  top: 50%; left: 0; right: 0;
  height: 3px;
  transform: translateY(-50%);
  background: linear-gradient(90deg, transparent 0%, var(--energy-orange) 30%, #fff 55%, var(--energy-orange) 80%, transparent 100%);
  clip-path: polygon(
    0% 50%, 5% 0%, 10% 100%, 15% 5%, 20% 95%,
    25% 0%, 30% 100%, 35% 8%, 40% 92%, 45% 2%,
    50% 98%, 55% 5%, 60% 95%, 65% 0%, 70% 100%,
    75% 8%, 80% 92%, 85% 3%, 90% 97%, 95% 5%,
    100% 50%, 100% 60%,
    95% 10%, 90% 100%, 85% 8%, 80% 97%,
    75% 13%, 70% 105%, 65% 5%, 60% 100%,
    55% 10%, 50% 103%, 45% 7%, 40% 97%,
    35% 13%, 30% 105%, 25% 5%, 20% 100%,
    15% 10%, 10% 105%, 5% 5%, 0% 60%
  );
  filter: drop-shadow(0 0 4px var(--energy-orange)) drop-shadow(0 0 8px var(--energy-orange)) drop-shadow(0 0 14px var(--energy-orange));
}

.crack-left::after {
  content: '';
  position: absolute;
  top: calc(50% + 8px);
  left: 8%; right: 30%;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.55), transparent);
  clip-path: polygon(
    0% 50%, 10% 0%, 22% 100%, 35% 10%,
    50% 90%, 65% 0%, 80% 80%, 100% 50%,
    100% 65%, 80% 90%, 65% 10%, 50% 100%,
    35% 20%, 22% 110%, 10% 8%, 0% 65%
  );
  filter: drop-shadow(0 0 5px rgba(255,255,255,0.8));
}

.crack-right::before {
  content: '';
  position: absolute;
  top: 50%; left: 0; right: 0;
  height: 3px;
  transform: translateY(-50%);
  background: linear-gradient(90deg, transparent 0%, var(--energy-orange) 20%, #fff 50%, var(--energy-orange) 75%, transparent 100%);
  clip-path: polygon(
    0% 50%, 4% 95%, 9% 2%, 14% 98%, 19% 3%,
    24% 97%, 29% 0%, 34% 100%, 39% 6%, 44% 94%,
    49% 1%, 54% 99%, 59% 4%, 64% 96%, 69% 0%,
    74% 100%, 79% 7%, 84% 93%, 89% 2%, 94% 98%,
    100% 50%, 100% 62%,
    94% 103%, 89% 7%, 84% 98%, 79% 12%,
    74% 105%, 69% 5%, 64% 101%, 59% 9%,
    54% 104%, 49% 6%, 44% 99%, 39% 11%,
    34% 105%, 29% 5%, 24% 102%, 19% 8%,
    14% 103%, 9% 7%, 4% 100%, 0% 62%
  );
  filter: drop-shadow(0 0 4px var(--energy-orange)) drop-shadow(0 0 8px var(--energy-orange)) drop-shadow(0 0 14px var(--energy-orange));
}

.crack-right::after {
  content: '';
  position: absolute;
  top: calc(50% - 8px);
  left: 30%; right: 8%;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  clip-path: polygon(
    0% 50%, 14% 100%, 28% 0%, 42% 85%,
    58% 15%, 72% 95%, 86% 5%, 100% 50%,
    100% 65%, 86% 10%, 72% 100%, 58% 25%,
    42% 95%, 28% 8%, 14% 110%, 0% 65%
  );
  filter: drop-shadow(0 0 5px rgba(255,255,255,0.7));
}

/* ── GLASS OVERLAY REAL EFFECT ── */
.glass-shatter-overlay {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
  z-index: 20;
  backdrop-filter: blur(0.4px);
  -webkit-backdrop-filter: blur(0.4px);
  opacity: 0.55;
  transition: opacity 0.3s;
}

.product-card:hover .glass-shatter-overlay {
  opacity: 0.85;
  backdrop-filter: blur(0.8px);
  -webkit-backdrop-filter: blur(0.8px);
}

/* ── DIVIDER — no icon, just crack lines ── */
.divider-section {
  position: absolute;
  top: 50%;
  width: 100%;
  height: 40px;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  gap: 0;
}

.bolt-nexus { display: none !important; }

/* ── ND CARD — MODERN SPLIT FRAME ── */
.nd-grid {
  display: flex;
  justify-content: center;
  gap: 2rem;
}

.nd-card {
  position: relative;
  width: 300px;
  display: flex;
  flex-direction: column;
  gap: 0;
  cursor: pointer;
  border-radius: 20px;
  overflow: hidden;
  background: #0d0d0d;
  border: 1px solid rgba(255,255,255,0.08);
  transition: transform 0.4s cubic-bezier(0.2,0,0.2,1), box-shadow 0.4s;
  box-shadow: 0 8px 40px rgba(0,0,0,0.5);
}

.nd-card:hover {
  transform: translateY(-10px) scale(1.02);
  box-shadow: 0 30px 80px rgba(0,0,0,0.7), 0 0 0 1px var(--ec), 0 0 40px rgba(249,115,22,0.15);
}

/* ── FRAMES ── */
.nd-frame {
  position: relative;
  width: 100%;
  height: 248px;
  overflow: hidden;
  flex-shrink: 0;
}

.nd-frame-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s cubic-bezier(0.2,0,0.2,1);
}

.nd-card:hover .nd-frame-img { transform: scale(1.07); }

/* top frame — slides up on hover */
.nd-frame-top { transform-origin: bottom center; }
.nd-card:hover .nd-frame-top { transform: translateY(-4px); }

/* bottom frame — slides down on hover */
.nd-frame-bottom { transform-origin: top center; }
.nd-card:hover .nd-frame-bottom { transform: translateY(4px); }

.nd-frame-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
  z-index: 1;
}

.nd-frame-overlay-bottom {
  background: linear-gradient(to bottom, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
}

/* badge */
.nd-badge {
  position: absolute;
  top: 12px; left: 12px;
  background: var(--ec);
  color: #fff;
  font-size: 0.48rem;
  font-weight: 900;
  letter-spacing: 2.5px;
  padding: 3px 10px;
  border-radius: 999px;
  z-index: 3;
  text-transform: uppercase;
}

.nd-badge-bottom { top: auto; bottom: 12px; }

/* title */
.nd-frame-title {
  position: absolute;
  bottom: 14px; left: 14px; right: 14px;
  color: #fff;
  font-size: 0.82rem;
  font-weight: 900;
  letter-spacing: -0.3px;
  line-height: 1.3;
  z-index: 3;
  text-shadow: 0 2px 12px rgba(0,0,0,0.9);
}

.nd-frame-title-bottom {
  bottom: auto;
  top: 14px;
}

/* corner accents — modern frame feel */
.nd-corner {
  position: absolute;
  width: 14px; height: 14px;
  z-index: 4;
  border-color: var(--ec);
  border-style: solid;
  opacity: 0.7;
  transition: opacity 0.3s, width 0.3s, height 0.3s;
}

.nd-card:hover .nd-corner { opacity: 1; width: 18px; height: 18px; }

.nd-corner-tl { top: 8px; left: 8px; border-width: 2px 0 0 2px; }
.nd-corner-tr { top: 8px; right: 8px; border-width: 2px 2px 0 0; }
.nd-corner-bl { bottom: 8px; left: 8px; border-width: 0 0 2px 2px; }
.nd-corner-br { bottom: 8px; right: 8px; border-width: 0 2px 2px 0; }

/* ── CRACK ZONE ── */
.nd-crack-zone {
  position: relative;
  width: 100%;
  height: 48px;
  flex-shrink: 0;
  background: #0d0d0d;
  z-index: 5;
  overflow: visible;
}

/* ── GLASS OVERLAY ── */
.nd-glass {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 20;
  opacity: 0.6;
  transition: opacity 0.3s;
  backdrop-filter: blur(0.3px);
  -webkit-backdrop-filter: blur(0.3px);
}

.nd-card:hover .nd-glass {
  opacity: 1;
  backdrop-filter: blur(0.6px);
  -webkit-backdrop-filter: blur(0.6px);
}

@media (max-width: 600px) {
  .nd-card { width: 100%; }
  .nd-grid { flex-direction: column; align-items: center; }
}

/* ── ND CARD CRACK FIX ── */
.nd-card {
  position: relative;
  flex-direction: column;
  gap: 0;
}

.nd-frame-top,
.nd-frame-bottom {
  position: relative;
  z-index: 1;
}

.nd-crack-zone {
  position: absolute;
  left: 0; right: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 48px;
  background: transparent !important;
  z-index: 10;
  pointer-events: none;
}

/* ── ND CRACK ZONE FINAL FIX ── */
.nd-crack-zone {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  height: 48px !important;
  background: transparent !important;
  z-index: 10 !important;
  pointer-events: none !important;
  flex-shrink: 0;
}

/* Remove any gap between frames */
.nd-frame-top,
.nd-frame-bottom {
  display: block;
  margin: 0;
  padding: 0;
}

.nd-card {
  overflow: hidden;
  position: relative;
}

/* ── ND CARD FINAL FIXES ── */

/* Hide all corner accents */
.nd-corner { display: none !important; }

/* Hide bottom badge */
.nd-badge-bottom { display: none !important; }

/* ── HOVER SPLIT EFFECT — frames pull apart ── */
.nd-card:hover .nd-frame-top {
  transform: translateY(-6px);
  transition: transform 0.4s cubic-bezier(0.2, 0, 0.2, 1);
}

.nd-card:hover .nd-frame-bottom {
  transform: translateY(6px);
  transition: transform 0.4s cubic-bezier(0.2, 0, 0.2, 1);
}

.nd-frame-top,
.nd-frame-bottom {
  transition: transform 0.4s cubic-bezier(0.2, 0, 0.2, 1);
}

/* crack zone stays fixed in center while frames move */
.nd-crack-zone {
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  height: 48px !important;
  background: transparent !important;
  z-index: 10 !important;
  pointer-events: none !important;
}

/* glow intensifies on hover */
.nd-card:hover .nd-crack-zone svg polyline {
  filter: drop-shadow(0 0 6px var(--ec)) drop-shadow(0 0 12px var(--ec));
}

/* ── SLOPED CRACK SPLIT ON HOVER ── */
.nd-frame-top {
  transform-origin: center bottom;
  transition: transform 0.45s cubic-bezier(0.2, 0, 0.2, 1);
}

.nd-frame-bottom {
  transform-origin: center top;
  transition: transform 0.45s cubic-bezier(0.2, 0, 0.2, 1);
}

.nd-card:hover .nd-frame-top {
  transform: translateY(-10px) rotate(-1.5deg) skewX(-1deg);
}

.nd-card:hover .nd-frame-bottom {
  transform: translateY(10px) rotate(1.5deg) skewX(1deg);
}

/* ── REAL CRACK BREAK OUT ── */
.nd-card {
  overflow: visible !important;
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}

.nd-card:hover {
  transform: none !important;
  box-shadow: none !important;
}

.nd-frame {
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0,0,0,0.6);
  border: 1px solid rgba(255,255,255,0.08);
}

.nd-card:hover .nd-frame-top {
  transform: translateY(-14px) rotate(-2deg) skewX(-1.5deg);
  box-shadow: 0 20px 60px rgba(0,0,0,0.7), 0 0 20px rgba(249,115,22,0.15);
}

.nd-card:hover .nd-frame-bottom {
  transform: translateY(14px) rotate(2deg) skewX(1.5deg);
  box-shadow: 0 20px 60px rgba(0,0,0,0.7), 0 0 20px rgba(249,115,22,0.15);
}

.nd-glass {
  border-radius: 12px;
  overflow: hidden;
}

/* ── REMOVE CARD BOX COMPLETELY ── */
.nd-card,
.nd-card:hover {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  outline: none !important;
  overflow: visible !important;
  transform: none !important;
}

.nd-glass { display: none !important; }

.nd-frame-top,
.nd-frame-bottom {
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.1);
  box-shadow: 0 10px 40px rgba(0,0,0,0.6);
}

.nd-card:hover .nd-frame-top {
  transform: translateY(-16px) rotate(-2.5deg) skewX(-1.5deg) !important;
  box-shadow: 0 24px 60px rgba(0,0,0,0.75), 0 0 24px rgba(249,115,22,0.2) !important;
}

.nd-card:hover .nd-frame-bottom {
  transform: translateY(16px) rotate(2.5deg) skewX(1.5deg) !important;
  box-shadow: 0 24px 60px rgba(0,0,0,0.75), 0 0 24px rgba(249,115,22,0.2) !important;
}

/* ── FRAMES JAGGED CRACK SHAPE ── */
.nd-frame-top {
  clip-path: polygon(
    0% 0%, 100% 0%, 100% 100%,
    97% 92%, 93% 100%, 89% 88%, 85% 98%, 81% 86%, 77% 96%, 73% 84%, 69% 95%, 65% 83%, 61% 94%, 57% 82%, 53% 97%, 49% 85%, 45% 96%, 41% 83%, 37% 95%, 33% 84%, 29% 97%, 25% 86%, 21% 98%, 17% 87%, 13% 99%, 9% 88%, 5% 97%, 2% 90%, 0% 100%
  );
}

.nd-frame-bottom {
  clip-path: polygon(
    0% 0%,
    2% 10%, 5% 3%, 9% 12%, 13% 1%, 17% 13%, 21% 2%, 25% 14%, 29% 3%, 33% 16%, 37% 5%, 41% 17%, 45% 4%, 49% 15%, 53% 3%, 57% 18%, 61% 6%, 65% 17%, 69% 5%, 73% 16%, 77% 4%, 81% 14%, 85% 2%, 89% 12%, 93% 0%, 97% 8%, 100% 0%,
    100% 100%, 0% 100%
  );
}

/* ── ND FRAME IMG CONTAIN ── */
.nd-frame-img {
  object-fit: contain !important;
  background: #0d0d0d;
}

/* ── ND FRAME TRANSPARENT BG ── */
.nd-frame,
.nd-frame-top,
.nd-frame-bottom,
.nd-frame-img,
.nd-card {
  background: transparent !important;
}

/* ── ND FRAME FULLY TRANSPARENT ── */
.nd-frame,
.nd-frame-top,
.nd-frame-bottom {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}

/* ── ND FRAME TITLE MODERN ── */
.nd-frame-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0.6rem 0.85rem;
  font-size: 0.78rem;
  font-weight: 900;
  color: #fff;
  letter-spacing: 0.5px;
  line-height: 1.2;
  text-transform: uppercase;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);
  text-shadow: 0 1px 6px rgba(0,0,0,0.9);
  z-index: 5;
  white-space: nowrap;
  overflow: visible;
  text-overflow: unset;
}

.nd-frame-title-bottom {
  bottom: auto;
  top: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.75) 0%, transparent 100%);
}

.nd-badge {
  z-index: 6;
  font-size: 0.45rem;
  letter-spacing: 2px;
  padding: 3px 8px;
}

/* ── ND TITLES AROUND CRACK ── */
.nd-title-top,
.nd-title-bottom {
  position: relative;
  z-index: 15;
  text-align: center;
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #fff;
  padding: 5px 12px;
  text-shadow: 0 0 12px rgba(249,115,22,0.8), 0 1px 4px rgba(0,0,0,0.9);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  background: transparent;
  pointer-events: none;
}

.nd-title-top {
  margin-bottom: -2px;
}

.nd-title-bottom {
  margin-top: -2px;
}

/* ── ND FRAME TITLE CLEAN ── */
.nd-frame-title {
  position: absolute;
  bottom: 14px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.12);
  color: #fff;
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 999px;
  white-space: nowrap;
  z-index: 5;
  text-shadow: none;
  background: none;
  pointer-events: none;
}

.nd-frame-title-bottom {
  bottom: auto;
  top: 14px;
}

/* hide outside titles */
.nd-title-top, .nd-title-bottom { display: none !important; }

/* ── ND TITLE BELOW LIMITED BADGE ── */
.nd-frame-title {
  position: absolute;
  top: 32px;
  left: 12px;
  right: 12px;
  bottom: auto;
  transform: none;
  background: none !important;
  backdrop-filter: none;
  border: none;
  color: #fff;
  font-size: 0.75rem;
  font-weight: 900;
  letter-spacing: 0.5px;
  text-transform: none;
  padding: 0;
  border-radius: 0;
  white-space: normal;
  line-height: 1.3;
  text-shadow: 0 2px 8px rgba(0,0,0,0.9);
  z-index: 5;
}

.nd-frame-title-bottom {
  top: 32px;
  bottom: auto;
}

/* ── NEW DROPS HEADER FIX ── */
.new-drops-section .uh-eyebrow {
  color: #f97316 !important;
}

.new-drops-section .uh-heading {
  color: #fff !important;
}

.uh-wrapper.light .new-drops-section .uh-heading {
  color: #111 !important;
}

.uh-heading-outline {
  -webkit-text-stroke: 1.5px #f97316 !important;
  -webkit-text-fill-color: transparent !important;
}

/* ── CT SECTION WRAP TRANSPARENT ── */
.ct-section-wrap {
  background: transparent !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
  border: none !important;
  box-shadow: none !important;
}

.uh-wrapper.light .ct-section-wrap {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
}

/* ── CT CARD LIGHT MODE ── */
.uh-wrapper.light .ct-card {
  background: rgba(0,0,0,0.06) !important;
  border: 1px solid rgba(0,0,0,0.1) !important;
}

.uh-wrapper.light .ct-card:hover {
  background: rgba(0,0,0,0.1) !important;
  border-color: rgba(249,115,22,0.4) !important;
}

/* ── CT SECTION WRAP DARK MODE BORDER ── */
.ct-section-wrap {
  border: 1px solid rgba(255,255,255,0.08) !important;
  border-radius: 2rem !important;
  padding: 2.5rem !important;
}

.uh-wrapper.light .ct-section-wrap {
  border: 1px solid rgba(0,0,0,0.08) !important;
}

/* ── CT SECTION WRAP BORDER BRIGHTER ── */
.ct-section-wrap {
  border: 1px solid rgba(255,255,255,0.18) !important;
}

.uh-wrapper.light .ct-section-wrap {
  border: 1px solid rgba(0,0,0,0.12) !important;
}

/* ── CT SECTION WRAP BORDER FINAL ── */
.ct-section-wrap {
  border: 1px solid rgba(255,255,255,1) !important;
}

.uh-wrapper.light .ct-section-wrap {
  border: 1px solid #93c5fd !important;
}

/* ── CT SECTION WRAP DARK BLUE BORDER ── */
.ct-section-wrap {
  border: 2px solid #1d4ed8 !important;
  border-radius: 2.5rem !important;
}

.uh-wrapper.light .ct-section-wrap {
  border: 2px solid #93c5fd !important;
  border-radius: 2.5rem !important;
}

/* ── LIGHT MODE FULL TEXT FIX ── */

/* Headings */
.uh-wrapper.light .ct-heading { color: #111 !important; }
.uh-wrapper.light .hiw-heading { color: #111 !important; }
.uh-wrapper.light .coll-step-title { color: #111 !important; }
.uh-wrapper.light .uh-heading { color: #111 !important; }

/* Descriptions */
.uh-wrapper.light .ct-desc { color: #444 !important; }
.uh-wrapper.light .hiw-desc { color: #444 !important; }
.uh-wrapper.light .coll-step-desc { color: #555 !important; }

/* Steps */
.uh-wrapper.light .hiw-step-title { color: #111 !important; }
.uh-wrapper.light .hiw-step-desc { color: #555 !important; }
.uh-wrapper.light .hiw-step-num { color: #f97316 !important; }

/* Labels */
.uh-wrapper.light .ct-color-label { color: #555 !important; }
.uh-wrapper.light .ct-eyebrow { color: #f97316 !important; }
.uh-wrapper.light .hiw-eyebrow { color: #f97316 !important; }

/* Products section */
.uh-wrapper.light .uh-products-header .ct-heading { color: #111 !important; }
.uh-wrapper.light .uh-products-header .ct-desc { color: #555 !important; }

/* Trust section */
.uh-wrapper.light .trust-rating-name { color: #111 !important; }
.uh-wrapper.light .trust-score { color: #111 !important; }
.uh-wrapper.light .trust-count { color: #555 !important; }
.uh-wrapper.light .trust-logo-text { color: #111 !important; }
.uh-wrapper.light .trust-stars { color: #f97316 !important; }

/* View all / buttons text */
.uh-wrapper.light .uh-view-all { color: #111 !important; border-color: rgba(0,0,0,0.2) !important; }
.uh-wrapper.light .uh-view-all:hover { color: #fff !important; }

/* Collection section */
.uh-wrapper.light .ct-heading-outline {
  -webkit-text-stroke-color: #f97316 !important;
}

/* How it works button */
.uh-wrapper.light .hiw-btn { color: #fff !important; }

/* nd-frame title in light mode */
.uh-wrapper.light .nd-frame-title { color: #fff !important; }
.uh-wrapper.light .nd-badge { color: #fff !important; }

/* ── LIGHT MODE ALL HEADINGS FORCE FIX ── */
.uh-wrapper.light h1,
.uh-wrapper.light h2,
.uh-wrapper.light h3,
.uh-wrapper.light h4,
.uh-wrapper.light p,
.uh-wrapper.light span:not(.ct-heading-outline):not(.hiw-heading-accent) {
  color: #111;
}

.uh-wrapper.light .ct-eyebrow,
.uh-wrapper.light .hiw-eyebrow,
.uh-wrapper.light .uh-eyebrow,
.uh-wrapper.light .ct-heading-outline,
.uh-wrapper.light .hiw-heading-accent,
.uh-wrapper.light .hiw-step-num,
.uh-wrapper.light .ct-card-arrow,
.uh-wrapper.light .trust-stars {
  color: #f97316 !important;
}

.uh-wrapper.light .ct-heading-outline {
  -webkit-text-fill-color: transparent !important;
  -webkit-text-stroke: 2px #f97316 !important;
}

.uh-wrapper.light .hiw-heading-accent {
  -webkit-text-fill-color: transparent !important;
  -webkit-text-stroke: 2px #f97316 !important;
}

.uh-wrapper.light .nd-frame-title,
.uh-wrapper.light .nd-badge,
.uh-wrapper.light .ct-card-name,
.uh-wrapper.light .ct-btn,
.uh-wrapper.light .hiw-btn,
.uh-wrapper.light .promo-heading,
.uh-wrapper.light .promo-badge-num,
.uh-wrapper.light .promo-badge-label {
  color: #fff !important;
}
